{
  "name": "forge",
  "description": "Self-hostable Discord form builder and approval engine.",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "convex dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "lint:code": "eslint .",
    "deploy": "npx @convex-dev/static-hosting deploy",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@convex-dev/static-hosting": "^0.1.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@robelest/convex-auth": "0.0.4-preview.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.25.0",
    "discord-interactions": "^4.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.5.1",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.3.3"
  },
  "overrides": {
    "effect": "4.0.0-beta.43",
    "@effect/platform-browser": "4.0.0-beta.43"
  }
}
